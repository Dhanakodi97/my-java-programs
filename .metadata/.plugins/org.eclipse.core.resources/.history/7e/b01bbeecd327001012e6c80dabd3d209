package igpWebScrapping;

import java.io.File;
import java.io.FileInputStream;
import java.io.IOException;
import java.time.Duration;
import java.util.List;

import org.apache.poi.ss.usermodel.Row;
import org.apache.poi.xssf.usermodel.XSSFSheet;
import org.apache.poi.xssf.usermodel.XSSFWorkbook;
import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;

public class IGPChatGpt {

    public static void main(String[] args) throws IOException {
        WebDriver driver = new ChromeDriver();
        driver.manage().window().maximize();

        try {
            FileInputStream file = new FileInputStream(new File(".\\Input\\IGPInput.xlsx"));
            XSSFWorkbook workbook = new XSSFWorkbook(file);
            XSSFSheet sheet = workbook.getSheetAt(0);
            System.out.println("Reading input data from Excel...");

            for (int i = 1; i <= sheet.getLastRowNum(); i++) {
                Row row = sheet.getRow(i);
                String searchKey = row.getCell(0).getStringCellValue();
                System.out.println("\nSearching for: " + searchKey);

                driver.get("https://www.igp.com/");
                WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(10));

                // Search product
                WebElement searchBar = wait.until(ExpectedConditions.elementToBeClickable(By.xpath("//input[@class='search-bar m-t-5 p-l-10 p-r-10 morphsearch-input']")));
                searchBar.clear();
                searchBar.sendKeys(searchKey);
                driver.findElement(By.xpath("//div[@class='icon-wrapper search-icon-wrapper']")).click();

                // Wait for products to load
                wait.until(ExpectedConditions.presenceOfAllElementsLocatedBy(By.xpath("//a[@class='image-holder']")));
                List<WebElement> products = driver.findElements(By.xpath("//div[@class='product-info-container']"));

                int count = Math.min(products.size(), 3); // limit to 3 items per search
                for (int j = 0; j < count; j++) {
                    try {
                        WebElement product = products.get(j);

                        String name = product.findElement(By.className("product-name")).getText();
                        String mrp = product.findElement(By.className("actual-price")).getText(); // MRP
                        String price = product.findElement(By.className("discount-price")).getText(); // Discounted price

                        String offer = "";
                        List<WebElement> offerElement = product.findElements(By.className("discount-tag"));
                        if (!offerElement.isEmpty()) {
                            offer = offerElement.get(0).getText();
                        }

                        System.out.println("Product " + (j + 1) + ":");
                        System.out.println("  Name: " + name);
                        System.out.println("  MRP: " + mrp);
                        System.out.println("  Selling Price: " + price);
                        System.out.println("  Offer: " + offer);
                    } catch (Exception e) {
                        System.out.println("  Error reading product " + (j + 1));
                    }
                }
            }

            workbook.close();
            file.close();

        } catch (Exception e) {
            e.printStackTrace();
        }

        driver.quit();
    }
}
